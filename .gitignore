/.venv/
/venv/
/env/
/.idea/
/.vscode/
*.code-workspace

# Runtime sink.
.var/

# Accidental root runtime artifacts.
/cache/
/logs/
/outputs/
/artifacts/
/runs/
/sessions/
/official_runs/
/leaderboard_runs/
/batch_runs/
/submissions/
/llm_cache/
/prompt_cache/
/raw_llm_outputs/
